DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/breach_alert
# REQUIRED. Generate a unique value (the app refuses to start otherwise):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: Get a free key at https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# Optional: dark-web / threat-intel feed key. Unset -> labelled "simulated" source.
DARKWEB_FEED_API_KEY=

# Continuous monitoring: background re-scan of all assets.
BACKGROUND_SCAN_ENABLED=true
SCAN_INTERVAL_MINUTES=60

# Optional: SMTP for real email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@breachalert.com
