# Groq API key for LLaMA 3.3-70B inference. Get one at https://console.groq.com
GROQ_API_KEY=

# Postgres + pgvector connection (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://crimegpt:crimegpt@localhost:5432/crimegpt

# Groq model + confidence threshold for the validation agent (0.0 - 1.0)
GROQ_MODEL=llama-3.3-70b-versatile
CONFIDENCE_THRESHOLD=0.6

# Where generated .docx + s.63 certificates are written
ARTIFACT_DIR=./artifacts
